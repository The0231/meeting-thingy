# ----------------------------------------------------------------------------
# Client Meeting Calendar — environment configuration
# Copy this file to ".env" and fill in values. ".env" is git-ignored.
# Everything here is OPTIONAL except DATABASE_URL — the app runs out of the box.
# ----------------------------------------------------------------------------

# Local SQLite database (default). To use PostgreSQL later, change the provider
# in prisma/schema.prisma to "postgresql" and set a postgres:// URL here.
DATABASE_URL="file:./dev.db"

# ---- AI features (all optional; the app works without them) -----------------

# Anthropic API key — enables AI meeting summaries & action-point extraction.
# Without it, the app still records meetings; you just summarise manually.
ANTHROPIC_API_KEY=""
# Model used for summaries (cheap + fast is fine here).
AI_MODEL="claude-haiku-4-5-20251001"

# OpenAI API key — OPTIONAL, only used to transcribe *uploaded* audio files
# server-side (Whisper). Live in-app recording transcribes for free in the
# browser via the Web Speech API and needs no key.
OPENAI_API_KEY=""
OPENAI_TRANSCRIBE_MODEL="whisper-1"

# ---- Power BI (optional) ----------------------------------------------------
# Syncs your client list and yearly sales value straight from a Power BI
# dataset, and matches each row to a client in this app by name.
#
# One-time setup (an admin does this once in the Azure portal):
#   1. portal.azure.com → Microsoft Entra ID → App registrations → New
#      registration. Name it e.g. "Client Calendar". Copy the "Application
#      (client) ID" and "Directory (tenant) ID" into the values below.
#   2. In the app registration → Certificates & secrets → New client secret.
#      Copy the secret VALUE (not the ID) into POWERBI_CLIENT_SECRET.
#   3. In app.powerbi.com → Settings (gear) → Admin portal → Tenant settings →
#      Developer settings → enable "Service principals can use Power BI APIs"
#      (limit it to a security group containing the app if you prefer).
#   4. Open the workspace that holds your sales report → Manage access → Add
#      the app ("Client Calendar") as a Member.
#   5. The workspace & dataset IDs are in the dataset's URL:
#      app.powerbi.com/groups/<WORKSPACE_ID>/datasets/<DATASET_ID>/...
#   6. Fill in the table & column names that hold the client name and the
#      sales amount (as shown in the report's data pane). Values are summed
#      per client, so a transactions table works fine.
POWERBI_TENANT_ID=""
POWERBI_CLIENT_ID=""
POWERBI_CLIENT_SECRET=""
POWERBI_WORKSPACE_ID=""
POWERBI_DATASET_ID=""
POWERBI_CLIENT_TABLE="Sales"
POWERBI_CLIENT_NAME_COLUMN="Client"
POWERBI_VALUE_COLUMN="Amount"
# Advanced: replace the generated query entirely with your own DAX. It must
# return one row per client with the client name in the first column and a
# numeric value aliased as [PBI_VALUE].
POWERBI_DAX_QUERY=""

# ---- Behaviour tuning -------------------------------------------------------

# Default follow-up interval (days) when a client has no history AND no
# setup answer yet ("how often do you normally visit?" is asked when the
# first meeting is recorded).
DEFAULT_INTERVAL_DAYS="30"
# How many days before the suggested date a client is flagged "due soon".
DUE_SOON_LEAD_DAYS="7"
# Yearly client value (£) that counts as a "top client" for priority scoring.
PRIORITY_VALUE_REFERENCE="100000"
