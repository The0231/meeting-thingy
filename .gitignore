# dependencies
/node_modules
/.pnp
.pnp.js

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# database (local SQLite) & uploaded audio — never commit client data
/prisma/dev.db
/prisma/dev.db-journal
/prisma/*.db
/prisma/*.db-journal
/uploads
/data

# env — never commit ANY env variant (all hold live secrets); the template
# .env.example is the only exception.
.env
.env.*
.env*.local
!.env.example

# misc
tsconfig.tsbuildinfo
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.vscode/*
!.vscode/extensions.json
